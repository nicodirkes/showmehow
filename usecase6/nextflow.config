
workDir = '.work'

params {
    // Total CPUs available to this workflow run.
    // Override with a fixed integer to run on a subset of the machine, e.g.:
    //   params.available_cpus = 16
    available_cpus = Runtime.runtime.availableProcessors()
}

process {
    withName: 'SERVE_MODEL_JL|SERVE_MODEL_PY|MCMC_CALIBRATION' {
        maxForks = {
            try {
                def cfg = new groovy.yaml.YamlSlurper().parseText(new File(params.config_file).text) as Map
                def nModel = (cfg.model?.n_workers ?: 1) as int
                def nCalib = (cfg.calibration?.n_workers ?: 1) as int
                Math.max(1, (int)(Runtime.runtime.availableProcessors() / (nModel + nCalib)))
            } catch (Exception ignored) { 1 }
        }()
    }
}

docker.enabled = true
// apptainer.enabled = true

conda.enabled = true
// conda.useMicromamba = true